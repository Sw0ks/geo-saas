# ─────────────────────────────────────────────────────────────────────────────
# GEO Analytics SaaS — шаблон переменных окружения
# Скопируйте в .env и заполните реальными значениями
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ─── PostgreSQL (используется в docker-compose.yml) ───────────────────────────
POSTGRES_USER=geo_user
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=geo_db

# ─── Подключение к БД (asyncpg) ───────────────────────────────────────────────
# В Docker hostname = имя сервиса "postgres"
# Локально = localhost
DATABASE_URL=postgresql+asyncpg://geo_user:change_me_strong_password@postgres/geo_db

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ─── Anthropic Claude API ─────────────────────────────────────────────────────
# Получить на: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ─── Yandex Cloud (YandexGPT / Алиса) ────────────────────────────────────────
# Получить на: https://console.yandex.cloud/
YANDEX_GPT_API_KEY=
YANDEX_CLOUD_FOLDER_ID=

# ─── GigaChat (Сбер) ──────────────────────────────────────────────────────────
# Получить на: https://developers.sber.ru/portal/products/gigachat
GIGACHAT_CLIENT_ID=
GIGACHAT_CLIENT_SECRET=
GIGACHAT_API_KEY=

# ─── ЮKassa (приём платежей) ──────────────────────────────────────────────────
# Получить на: https://yookassa.ru/
YOKASSA_SHOP_ID=
YOKASSA_SECRET_KEY=

# ─── JWT / NextAuth ───────────────────────────────────────────────────────────
# Сгенерировать: openssl rand -hex 32
JWT_SECRET=
NEXTAUTH_SECRET=
# Для локальной разработки: http://localhost:3000
# Для прода: https://yourdomain.ru
NEXTAUTH_URL=https://yourdomain.ru

# ─── Приложение ───────────────────────────────────────────────────────────────
DOMAIN=yourdomain.ru
TRACKER_ENDPOINT=https://yourdomain.ru/v1/track

# ─── SMTP (email-уведомления) ─────────────────────────────────────────────────
# Яндекс Почта для домена: smtp.yandex.ru:465
# Gmail: smtp.gmail.com:587
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
# Адрес отправителя, например: noreply@yourdomain.ru
SMTP_FROM=
